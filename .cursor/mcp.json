{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--profile", "./browser-profile",
        "--caps=pdf",
        "--output-dir", "./extracted/downloads"
      ]
    },
    "slack": {
      "url": "https://mcp.slack.com/mcp",
      "headers": {
        "Authorization": "Bearer ${SLACK_BOT_TOKEN}"
      }
    }
  }
}
