# Cloud Build ignore — separate from .gitignore because gcloud builds submit
# uses .gcloudignore (falling back to .gitignore). We need store-profiles/
# in the build context even though .gitignore excludes most of knowledge-base/.

.git
__pycache__
*.pyc
.pytest_cache
extracted/
agents/*/knowledge-base/training-data/
agents/*/knowledge-base/embeddings/
agents/*/knowledge-base/raw-documents/
agents/*/knowledge-base/adp-exports/
agents/*/knowledge-base/square-exports/
agents/*/knowledge-base/historical-verification/
!agents/*/knowledge-base/store-profiles/
!agents/*/knowledge-base/store-profiles/**
/credentials/
!skills/credentials/
.bhaga/
.cursor/
.vscode/
tests/
playground/
Jarvis/
.playwright-profile/
browser-profile/
*.mp4
*.pdf
downloads/
config.yaml
config.template.yaml
.DS_Store
