# Agent-specific data (PII, financials, account numbers)
agents/*/knowledge-base/*.json
agents/*/knowledge-base/questionnaire-*.md
agents/*/data/
extracted/
config.yaml

# One-time scripts with hardcoded personal data
agents/*/scripts/personal/

# Credential storage (actual creds in Keychain, never files)
credentials/
!credentials/portals.yaml.template

# Browser automation profile (session cookies)
browser-profile/

# Downloaded documents
*.pdf
*.csv
*.mp4
*.xlsx
*.eml

# OS / IDE
.DS_Store
__pycache__/
*.pyc

# Allow schema docs and examples (override *.json exclusion)
!agents/*/knowledge-base/schema/
!agents/*/knowledge-base/examples/

# Portal playbooks and scripts are user-specific (reveal which portals you use)
# Only generic templates are tracked; actual portal files are gitignored
agents/*/knowledge-base/portal-playbooks/*.yaml
!agents/*/knowledge-base/portal-playbooks/_template.yaml
agents/*/scripts/portals/*.py
!agents/*/scripts/portals/__init__.py
!agents/*/scripts/portals/_brokerage_template.py
!agents/*/scripts/portals/_county_tax_template.py
