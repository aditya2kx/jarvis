# Agent-specific data (PII, financials, account numbers, store IDs).
# Recursive: nothing under any knowledge-base/ folder ships to GitHub.
# README.md files are explicitly allowed back in for repo navigation.
agents/*/knowledge-base/**
!agents/*/knowledge-base/
!agents/*/knowledge-base/**/
!agents/*/knowledge-base/**/README.md
!agents/*/knowledge-base/**/DOMAIN.md
!agents/*/knowledge-base/store-profiles/
!agents/*/knowledge-base/store-profiles/**
agents/*/data/
extracted/
config.yaml

# Local scratch / planning space — never ships to GitHub.
Playground/
# Dev chat transcripts dropped at the repo root for analysis.
chat transcript*

# One-time scripts with hardcoded personal data
agents/*/scripts/personal/

# Credential storage (actual creds in Keychain, never files)
credentials/
!credentials/portals.yaml.template
!credentials/import_from_chrome.py
!credentials/store_credential.py

# Credential registry metadata (account names, service names)
skills/credentials/registry.json

# Browser automation profile (session cookies)
browser-profile/

# user_model raw corpus — append-only log of every user turn.
# The distilled, curated preferences live at .cursor/rules/user-preferences.md
# (gittracked + auto-loads). The raw corpus is private + never shared.
skills/user_model/data/

# Downloaded documents
*.pdf
*.csv
*.mp4
*.xlsx
*.eml

# OS / IDE
.DS_Store
__pycache__/
*.pyc

# Allow synthetic CSV test fixtures (no PII — required by CI/pytest)
!**/fixtures/**/*.csv

# Allow schema docs and examples (override *.json exclusion)
!agents/*/knowledge-base/schema/
!agents/*/knowledge-base/examples/

# Portal navigation modules are checked in (generic knowledge, no PII).
# The user's portal manifest (which portals they use + account details)
# lives in config.yaml (already gitignored).
!agents/*/knowledge-base/portal-playbooks/
!agents/*/scripts/portals/
