# Agent-specific data (PII, financials, account numbers)
agents/*/knowledge-base/*.json
agents/*/knowledge-base/questionnaire-*.md
agents/*/data/
extracted/
config.yaml

# One-time scripts with hardcoded personal data
agents/*/scripts/personal/

# Credential storage (actual creds in Keychain, never files)
credentials/
!credentials/portals.yaml.template

# Browser automation profile (session cookies)
browser-profile/

# Downloaded documents
*.pdf
*.csv
*.mp4
*.xlsx
*.eml

# OS / IDE
.DS_Store
__pycache__/
*.pyc

# Allow schema docs and examples (override *.json exclusion)
!agents/*/knowledge-base/schema/
!agents/*/knowledge-base/examples/

# Portal navigation modules are checked in (generic knowledge, no PII).
# The user's portal manifest (which portals they use + account details)
# lives in config.yaml (already gitignored).
!agents/*/knowledge-base/portal-playbooks/
!agents/*/scripts/portals/
