        {
          "refId": "A",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "rawSql": "SELECT TIMESTAMP(date, 'America/Chicago') AS time, total_hours_per_1k_net_sales AS `hrs_per_net_sales`, hours_per_item AS `hrs_per_item`, CAST('$goal_hours_per_net_sales' AS FLOAT64) AS `goal_net_sales`, CAST('$goal_hours_per_item' AS FLOAT64) AS `goal_item` FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_daily` WHERE date >= DATE('$date_from') ORDER BY date"
