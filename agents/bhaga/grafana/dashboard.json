{
  "uid": "bhaga-analytics-v1",
  "title": "BHAGA Analytics",
  "description": "Order volume, labor cost, and payroll metrics for BHAGA (Palmetto). Powered by BQ views from migration 004.",
  "graphTooltip": 1,
  "schemaVersion": 38,
  "version": 5,
  "refresh": "1h",
  "timezone": "America/Chicago",
  "time": {"from": "now-90d", "to": "now"},
  "timepicker": {},
  "tags": ["bhaga", "palmetto", "analytics"],
  "templating": {
    "list": [
      {
        "name": "date_from",
        "label": "From Date",
        "type": "textbox",
        "current": {"value": "2026-01-01"},
        "options": [{"selected": true, "text": "2026-01-01", "value": "2026-01-01"}],
        "hide": 0,
        "description": "ISO date string e.g. 2026-01-01"
      },
      {
        "name": "ds_bigquery",
        "label": "BigQuery Datasource",
        "type": "datasource",
        "pluginId": "grafana-bigquery-datasource",
        "current": {"value": "BHAGA BigQuery"},
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "id": 10,
      "type": "row",
      "title": "A. Order Volume",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Daily Order Count",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60}
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT TIMESTAMP(date, 'America/Chicago') AS time, orders FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_daily` WHERE date >= DATE('$date_from') ORDER BY date",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"}
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Weekly Order Count",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60}
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT TIMESTAMP(week_start, 'America/Chicago') AS time, orders FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_weekly` WHERE week_start >= DATE('$date_from') ORDER BY week_start",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"}
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Daily Item Count",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60}
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT TIMESTAMP(date, 'America/Chicago') AS time, items_sold FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_daily` WHERE date >= DATE('$date_from') ORDER BY date",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"}
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Weekly Item Count",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60}
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT TIMESTAMP(week_start, 'America/Chicago') AS time, items_sold FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_weekly` WHERE week_start >= DATE('$date_from') ORDER BY week_start",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"}
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "B. Labor Cost",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17}
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Daily Labor % of Net Sales",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {"lineWidth": 2},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.28},
              {"color": "red", "value": 0.35}
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT TIMESTAMP(date, 'America/Chicago') AS time, labor_pct AS total, hourly_pct AS part_time, fulltime_pct AS full_time FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_daily` WHERE date >= DATE('$date_from') ORDER BY date",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"}
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Weekly Labor % of Net Sales",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {"lineWidth": 2},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.28},
              {"color": "red", "value": 0.35}
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT TIMESTAMP(week_start, 'America/Chicago') AS time, labor_pct AS total, hourly_pct AS part_time, fulltime_pct AS full_time FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_weekly` WHERE week_start >= DATE('$date_from') ORDER BY week_start",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"}
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Daily Hours per Item",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {"lineWidth": 2}
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT TIMESTAMP(date, 'America/Chicago') AS time, hours_per_item FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_daily` WHERE date >= DATE('$date_from') ORDER BY date",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"}
        }
      ]
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Weekly Hours per Item",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {"lineWidth": 2}
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT TIMESTAMP(week_start, 'America/Chicago') AS time, hours_per_item FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_weekly` WHERE week_start >= DATE('$date_from') ORDER BY week_start",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"}
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "C. Payroll",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 34}
    },
    {
      "id": 31,
      "type": "table",
      "title": "Payroll — per Employee per Pay Period",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 35},
      "options": {
        "sortBy": [{"displayName": "period_start", "desc": true}],
        "footer": {"show": false}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "est_gross_pay"},
            "properties": [
              {"id": "unit", "value": "currencyUSD"},
              {"id": "displayName", "value": "Gross Pay (est)"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "tips_allocated"},
            "properties": [
              {"id": "unit", "value": "currencyUSD"},
              {"id": "displayName", "value": "Tips Allocated"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "review_bonus"},
            "properties": [
              {"id": "unit", "value": "currencyUSD"},
              {"id": "displayName", "value": "Review Bonus"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "est_total_pay"},
            "properties": [
              {"id": "unit", "value": "currencyUSD"},
              {"id": "displayName", "value": "Total (est)"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "period_start"},
            "properties": [{"id": "displayName", "value": "Period Start"}]
          },
          {
            "matcher": {"id": "byName", "options": "period_end"},
            "properties": [{"id": "displayName", "value": "Period End"}]
          },
          {
            "matcher": {"id": "byName", "options": "hours_worked"},
            "properties": [{"id": "displayName", "value": "Hours"}]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT CAST(period_start AS STRING) AS period_start, CAST(period_end AS STRING) AS period_end, employee, hours_worked, est_gross_pay, tips_allocated, review_bonus, est_total_pay FROM `jarvis-bhaga-prod.bhaga.vw_model_payroll_period` WHERE period_start >= DATE('$date_from') ORDER BY period_start DESC, employee",
          "format": 1,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"}
        }
      ]
    }
  ]
}
