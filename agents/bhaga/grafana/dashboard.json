      "title": "Payroll — per Employee per Pay Period",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 80},
      "options": {"sortBy": [{"displayName": "period_start", "desc": true}]},
      "fieldConfig": {
        "overrides": [
          {"matcher": {"id": "byName", "options": "period_start"}, "properties": [{"id": "displayName", "value": "Period Start"}]},
          {"matcher": {"id": "byName", "options": "period_end"}, "properties": [{"id": "displayName", "value": "Period End"}]},
          {"matcher": {"id": "byName", "options": "employee"}, "properties": [{"id": "displayName", "value": "Employee"}]},
          {"matcher": {"id": "byName", "options": "hours_worked"}, "properties": [{"id": "displayName", "value": "Hours"}, {"id": "unit", "value": "h"}]},
          {"matcher": {"id": "byName", "options": "est_gross_pay"}, "properties": [{"id": "displayName", "value": "Gross Pay (est)"}, {"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "adp_wages_paid"}, "properties": [{"id": "displayName", "value": "ADP Wages"}, {"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "wage_diff"}, "properties": [{"id": "displayName", "value": "Wage Diff"}, {"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "tips_allocated"}, "properties": [{"id": "displayName", "value": "Tips (calc)"}, {"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "adp_tips_paid"}, "properties": [{"id": "displayName", "value": "ADP Tips"}, {"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "tip_diff"}, "properties": [{"id": "displayName", "value": "Tip Diff"}, {"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "review_bonus"}, "properties": [{"id": "displayName", "value": "Review Bonus (calc)"}, {"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "adp_bonus_paid"}, "properties": [{"id": "displayName", "value": "ADP Bonus"}, {"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "bonus_diff"}, "properties": [{"id": "displayName", "value": "Bonus Diff"}, {"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "est_total_pay"}, "properties": [{"id": "displayName", "value": "Total (est)"}, {"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "adp_total_paid"}, "properties": [{"id": "displayName", "value": "ADP Total"}, {"id": "unit", "value": "currencyUSD"}]}
        ]
      },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "rawSql": "SELECT CAST(period_start AS STRING) period_start, CAST(period_end AS STRING) period_end, employee, hours_worked, est_gross_pay, adp_wages_paid, wage_diff, tips_allocated, adp_tips_paid, tip_diff, review_bonus, adp_bonus_paid, bonus_diff, est_total_pay, adp_total_paid FROM `jarvis-bhaga-prod.bhaga.vw_model_payroll_period` WHERE period_start >= DATE('$date_from') ORDER BY period_start DESC, employee"
        }
      ]
    }

  ]
