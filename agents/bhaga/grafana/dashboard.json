    {
      "id": 32,
      "type": "timeseries",
      "title": "Daily Total Hours: / Net Sales & / Item (vs goals)",
      "description": "Labor efficiency: shift hours per $1,000 net sales (left axis) and per item sold (right axis). Lower is leaner. Dashed lines are the goal baselines — set via the 'Goal: …' variables at the top.",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 21},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {"unit": "h"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "hrs_per_net_sales"}, "properties": [{"id": "displayName", "value": "Hrs / Net Sales ($1K)"}]},
          {"matcher": {"id": "byName", "options": "hrs_per_item"}, "properties": [{"id": "displayName", "value": "Hrs / Item"}, {"id": "custom.axisPlacement", "value": "right"}]},
          {"matcher": {"id": "byName", "options": "goal_net_sales"}, "properties": [{"id": "displayName", "value": "Goal / Net Sales ($1K)"}, {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}, {"id": "custom.lineWidth", "value": 1}]},
          {"matcher": {"id": "byName", "options": "goal_item"}, "properties": [{"id": "displayName", "value": "Goal / Item"}, {"id": "custom.axisPlacement", "value": "right"}, {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}, {"id": "custom.lineWidth", "value": 1}]}
        ]
