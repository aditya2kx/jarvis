          "rawSql": "SELECT TIMESTAMP(date, 'America/Chicago') AS time, total_hours AS `Total`, hourly_hours AS `Part-time`, fulltime_hours AS `Full-time` FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_daily` WHERE date >= DATE('$date_from') ORDER BY date"
        }
