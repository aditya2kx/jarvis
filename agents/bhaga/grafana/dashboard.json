{
  "uid": "bhaga-analytics-v1",
  "title": "BHAGA Analytics",
  "description": "5-section dashboard: Daily Sales, Weekly Sales, Labor, Order Quality, Payroll. Powered by BQ views from migrations 004 + 005.",
  "graphTooltip": 1,
  "schemaVersion": 38,
  "version": 6,
  "refresh": "1h",
  "timezone": "America/Chicago",
  "time": {"from": "now-90d", "to": "now"},
  "timepicker": {},
  "tags": ["bhaga", "palmetto", "analytics"],
  "templating": {
    "list": [
      {
        "name": "date_from",
        "label": "From Date",
        "type": "textbox",
        "current": {"value": "2026-01-01"},
        "options": [{"selected": true, "text": "2026-01-01", "value": "2026-01-01"}],
        "hide": 0,
        "description": "ISO date string e.g. 2026-01-01"
      },
      {
        "name": "inv_date",
        "label": "Investigation Date",
        "type": "textbox",
        "current": {"value": "2026-06-03"},
        "options": [{"selected": true, "text": "2026-06-03", "value": "2026-06-03"}],
        "hide": 0,
        "description": "Date to investigate for slow items / staff on shift (YYYY-MM-DD)"
      },
      {
        "name": "max_item_min",
        "label": "Slow Item Threshold (min)",
        "type": "textbox",
        "current": {"value": "8"},
        "options": [{"selected": true, "text": "8", "value": "8"}],
        "hide": 0,
        "description": "Show items with per_item_min >= this value in the investigation table"
      },
      {
        "name": "ds_bigquery",
        "label": "BigQuery Datasource",
        "type": "datasource",
        "pluginId": "grafana-bigquery-datasource",
        "current": {"value": "BHAGA BigQuery"},
        "hide": 2
      }
    ]
  },
  "panels": [

    {
      "id": 10,
      "type": "row",
      "title": "1. Daily Sales Overview",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Daily Order & Item Volume",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 1},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Items Sold"},
            "properties": [
              {"id": "custom.axisPlacement", "value": "right"},
              {"id": "custom.drawStyle", "value": "line"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Orders"},
            "properties": [
              {"id": "custom.drawStyle", "value": "bars"}
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "rawSql": "SELECT TIMESTAMP(date, 'America/Chicago') AS time, orders AS \"Orders\", items_sold AS \"Items Sold\" FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_daily` WHERE date >= DATE('$date_from') ORDER BY date"
        }
      ]
    },

    {
      "id": 20,
      "type": "row",
      "title": "2. Weekly Sales Overview",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 10}
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Weekly Order & Item Volume",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 11},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Items Sold"},
            "properties": [
              {"id": "custom.axisPlacement", "value": "right"},
              {"id": "custom.drawStyle", "value": "line"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Orders"},
            "properties": [
              {"id": "custom.drawStyle", "value": "bars"}
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "rawSql": "SELECT TIMESTAMP(week_start, 'America/Chicago') AS time, orders AS \"Orders\", items_sold AS \"Items Sold\" FROM `jarvis-bhaga-prod.bhaga.vw_model_labor_weekly` WHERE week_start >= DATE('$date_from') ORDER BY week_start"
        }
      ]
    },

