    {
      "id": 50,
      "type": "row",
      "title": "4. Order Quality",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 57}
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "KDS Time per Item (median / p90 / p95 / p99)",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 58},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {"unit": "m", "decimals": 0, "min": 0, "max": 30}
      },
      "targets": [
        {
          "refId": "A",
          "format": 0,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "rawSql": "SELECT TIMESTAMP(date, 'America/Chicago') AS time, kds_p90_min AS `p90`, kds_p95_min AS `p95`, kds_p99_min AS `p99`, kds_median_min AS `median` FROM `jarvis-bhaga-prod.bhaga.vw_order_quality_daily` WHERE date >= DATE('$date_from') ORDER BY date"
        }
      ]
    },
    {
      "id": 52,
      "type": "table",
      "title": "Slow Orders — Items by Ticket (date: $inv_date, ≥$max_item_min min/item)",
      "description": "Each slow ORDER (ticket) and all of its items, so you can see what was in a long order. KDS records time per order, not per item — 'Order Min' is the whole ticket's time and 'Avg Min/Item' = Order Min ÷ items in order (same for every row of a ticket). So this shows which orders ran long and what they contained, but not which single item inside a multi-item order was the bottleneck. Rows are grouped by order (slowest first). Filter: orders whose avg min/item ≥ $max_item_min.",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 12, "w": 14, "x": 0, "y": 67},
      "options": {"sortBy": [{"displayName": "Order Min", "desc": true}]},
      "fieldConfig": {
        "overrides": [
          {"matcher": {"id": "byName", "options": "ticket_name"}, "properties": [{"id": "displayName", "value": "Order"}]},
          {"matcher": {"id": "byName", "options": "order_source"}, "properties": [{"id": "displayName", "value": "Source"}]},
          {"matcher": {"id": "byName", "options": "time_created"}, "properties": [{"id": "displayName", "value": "Time"}]},
          {"matcher": {"id": "byName", "options": "device_name"}, "properties": [{"id": "displayName", "value": "Station"}]},
          {"matcher": {"id": "byName", "options": "num_items"}, "properties": [{"id": "displayName", "value": "Items in Order"}]},
          {"matcher": {"id": "byName", "options": "ticket_min"}, "properties": [{"id": "displayName", "value": "Order Min"}]},
          {"matcher": {"id": "byName", "options": "per_item_min"}, "properties": [{"id": "displayName", "value": "Avg Min/Item"}]},
          {"matcher": {"id": "byName", "options": "item_name"}, "properties": [{"id": "displayName", "value": "Item"}]},
          {"matcher": {"id": "byName", "options": "qty"}, "properties": [{"id": "displayName", "value": "Qty"}]},
          {"matcher": {"id": "byName", "options": "category"}, "properties": [{"id": "displayName", "value": "Category"}]}
        ]
      },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "rawSql": "SELECT ticket_name, order_source, time_created, device_name, num_items, ticket_min, per_item_min, item_name, qty, category FROM `jarvis-bhaga-prod.bhaga.vw_kds_item_investigation` WHERE date_local = '$inv_date' AND per_item_min >= CAST('$max_item_min' AS INT64) ORDER BY ticket_min DESC, ticket_name, item_name"
        }
      ]
    },
    {
      "id": 53,
      "type": "table",
      "title": "Who Worked That Shift ($inv_date)",
      "datasource": {"type": "grafana-bigquery-datasource", "uid": "${ds_bigquery}"},
      "gridPos": {"h": 12, "w": 10, "x": 14, "y": 67},
      "options": {"sortBy": [{"displayName": "in_time", "desc": false}]},
      "fieldConfig": {
        "overrides": [
          {"matcher": {"id": "byName", "options": "employee"}, "properties": [{"id": "displayName", "value": "Employee"}]},
          {"matcher": {"id": "byName", "options": "in_time"}, "properties": [{"id": "displayName", "value": "In"}]},
          {"matcher": {"id": "byName", "options": "out_time"}, "properties": [{"id": "displayName", "value": "Out"}]},
          {"matcher": {"id": "byName", "options": "total_hours"}, "properties": [{"id": "displayName", "value": "Hours"}, {"id": "unit", "value": "h"}]}
        ]
      },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "project": "jarvis-bhaga-prod",
          "dataset": "bhaga",
          "rawSql": "SELECT employee, in_time, out_time, total_hours FROM `jarvis-bhaga-prod.bhaga.vw_staff_on_shift` WHERE date = '$inv_date' ORDER BY in_time"
        }
      ]
    },

