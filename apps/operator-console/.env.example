BQ_PROJECT=jarvis-bhaga-prod
BQ_DATASET=bhaga
GEMINI_TOKEN=            # from Secret Manager at runtime, not committed

# Plaid (Issue #158 Accounting) — sandbox for local Link tests
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# PLAID_WEBHOOK_URL=https://bhaga-webhook-….run.app/plaid/webhook

# Local dev only: bypasses the IAP header check in lib/auth/identity.ts when
# there is no IAP proxy in front of `next dev`. Never set in prod — IAP
# forwards x-goog-authenticated-user-email itself.
BYPASS_IAP_EMAIL=you@mypalmetto.co
