{
  "uid": "jarvis-dev-cost-v1",
  "title": "Jarvis Development",
  "description": "Per-PR build/review/total cost for Jarvis development. Source: jarvis_dev.vw_pr_cost.",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1h",
  "timezone": "America/Chicago",
  "time": { "from": "now-90d", "to": "now" },
  "tags": ["jarvis", "dev", "cost"],
  "templating": { "list": [
    { "name": "ds_bigquery", "type": "datasource", "query": "grafana-bigquery-datasource",
      "current": { "text": "BHAGA BigQuery", "value": "BHAGA BigQuery" }, "hide": 0 }
  ] },
  "panels": [
    { "id": 1, "type": "stat", "title": "Total dev spend",
      "gridPos": {"h":4,"w":6,"x":0,"y":0},
      "datasource": {"type":"grafana-bigquery-datasource","uid":"${ds_bigquery}"},
      "fieldConfig": {"defaults": {"unit":"currencyUSD"}},
      "targets": [{"datasource":{"type":"grafana-bigquery-datasource","uid":"${ds_bigquery}"},
        "rawSql":"SELECT SUM(total_cost_usd) AS `total` FROM `jarvis-bhaga-prod.jarvis_dev.vw_pr_cost`",
        "format":"table","location":"US"}] },
    { "id": 4, "type": "stat", "title": "PRs shipped",
      "gridPos": {"h":4,"w":4,"x":6,"y":0},
      "datasource": {"type":"grafana-bigquery-datasource","uid":"${ds_bigquery}"},
      "fieldConfig": {"defaults": {"unit":"none"}},
      "targets": [{"datasource":{"type":"grafana-bigquery-datasource","uid":"${ds_bigquery}"},
        "rawSql":"SELECT COUNT(*) AS `count` FROM `jarvis-bhaga-prod.jarvis_dev.vw_pr_cost`",
        "format":"table","location":"US"}] },
    { "id": 5, "type": "stat", "title": "Avg cost per PR",
      "gridPos": {"h":4,"w":6,"x":10,"y":0},
      "datasource": {"type":"grafana-bigquery-datasource","uid":"${ds_bigquery}"},
      "fieldConfig": {"defaults": {"unit":"currencyUSD"}},
      "targets": [{"datasource":{"type":"grafana-bigquery-datasource","uid":"${ds_bigquery}"},
        "rawSql":"SELECT AVG(total_cost_usd) AS `avg` FROM `jarvis-bhaga-prod.jarvis_dev.vw_pr_cost`",
        "format":"table","location":"US"}] },
    { "id": 2, "type": "timeseries", "title": "Cost per PR (build vs review)",
      "gridPos": {"h":9,"w":24,"x":0,"y":4},
      "datasource": {"type":"grafana-bigquery-datasource","uid":"${ds_bigquery}"},
      "fieldConfig": {"defaults": {"unit":"currencyUSD"}},
      "targets": [{"datasource":{"type":"grafana-bigquery-datasource","uid":"${ds_bigquery}"},
        "rawSql":"SELECT PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*SZ', merged_at) AS time, CAST(pr_number AS STRING) AS pr_number, build_cost_usd AS `build`, review_cost_usd AS `review` FROM `jarvis-bhaga-prod.jarvis_dev.vw_pr_cost` ORDER BY merged_at",
        "format":"table","location":"US"}] },
    { "id": 3, "type": "table", "title": "Per-PR cost ledger",
      "gridPos": {"h":12,"w":24,"x":0,"y":13},
      "datasource": {"type":"grafana-bigquery-datasource","uid":"${ds_bigquery}"},
      "targets": [{"datasource":{"type":"grafana-bigquery-datasource","uid":"${ds_bigquery}"},
        "rawSql":"SELECT pr_number, title, build_cost_usd, review_cost_usd, review_runs, total_cost_usd, merged_at FROM `jarvis-bhaga-prod.jarvis_dev.vw_pr_cost` ORDER BY pr_number DESC",
        "format":"table","location":"US"}] }
  ]
}
