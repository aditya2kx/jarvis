#!/usr/bin/env bash
# Post-merge hook: regenerate the cost report immediately after `git pull` on main.
#
# Install once per clone/worktree with: bash scripts/install-git-hooks.sh
#
# Why: pr-cost-finalize.yml computes the correct merged_at and final review cost
# post-merge, but the repo ruleset blocks all direct pushes to main (including from
# ADMIN_PAT), so it can never commit the finalized values. As a result the committed
# ledger always lags one PR: the just-merged PR's record has merged_at=null and
# report.html doesn't show it until the *next* PR's pre-commit hook fires.
#
# This hook fires on every `git pull --ff` / `git merge` that lands new commits. On
# branch `main` it runs `pr_cost_ledger.py report`, which:
#   1. Calls _is_merged_for_report() for every ledger PR — if merged_at is null it
#      queries GitHub once, persists the value, and returns True. This WRITES the
#      corrected merged_at to the local PR-<n>.json files.
#   2. Regenerates report.html so `file:///…/report.html` is correct immediately.
#
# The updated JSON + HTML are local-only; they are NOT committed here. They will
# ride into the next commit via the pre-commit hook (git add metrics/pr_cost/).
# To commit and push them RIGHT NOW, run: bash scripts/finalize_cost.sh <pr>
#
# Behavior: no-op on any branch other than main. Never blocks the merge.
# Skip with: PR_COST_HOOK=0
set -euo pipefail

[ "${PR_COST_HOOK:-1}" = "0" ] && exit 0

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
[ "$branch" != "main" ] && exit 0

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "pr-cost: post-merge on main — regenerating report + backfilling merged_at…" >&2
python3 scripts/pr_cost_ledger.py report >&2 2>&1 || \
  echo "pr-cost: report regeneration skipped (non-fatal)." >&2
exit 0
