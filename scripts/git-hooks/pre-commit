#!/usr/bin/env bash
# Pre-commit hook: capture review cost into BQ for the current PR.
#
# Install once per clone with: bash scripts/install-git-hooks.sh
#
# The PR cost ledger lives in BigQuery (jarvis_dev). This hook captures any
# review cost posted as PR comments into BQ so the gate can see it. Build cost
# must be recorded explicitly by the author (record-build or capture-build).
#
# Set PR_COST_HOOK=0 to skip (e.g. a quick WIP commit).
set -euo pipefail

[ "${PR_COST_HOOK:-1}" = "0" ] && exit 0

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

branch="$(git rev-parse --abbrev-ref HEAD)"
[ "$branch" = "main" ] && exit 0

command -v gh >/dev/null 2>&1 || exit 0
pr="$(gh pr view "$branch" --json number -q .number 2>/dev/null || true)"
[ -z "$pr" ] && exit 0

echo "pr-cost: capturing review cost for PR #$pr into BQ…" >&2
python3 scripts/pr_cost_ledger.py capture-review --pr "$pr" >/dev/null 2>&1 || true
exit 0
