#!/usr/bin/env bash
# Opt-in pre-push hook: keep the per-PR cost ledger current before every push.
#
# Install with: bash scripts/install-git-hooks.sh
#
# Behavior: on a feature branch that has an open PR, run `pr_cost_ledger.py sync`
# (capture build + review cost, regenerate metrics/pr_cost/report.html). If that
# changes the ledger/report, BLOCK the push and ask you to commit + push again —
# so the pushed commit always carries the cost-so-far. The only thing it can't
# hold is the review run THIS push triggers; that tail is finalized at merge by
# .github/workflows/pr-cost-finalize.yml. No auto-commit — you stay in control.
set -euo pipefail

branch="$(git rev-parse --abbrev-ref HEAD)"
[ "$branch" = "main" ] && exit 0

# Skip cleanly if gh isn't available/authed or there's no PR for this branch yet.
command -v gh >/dev/null 2>&1 || exit 0
pr="$(gh pr view "$branch" --json number -q .number 2>/dev/null || true)"
[ -z "$pr" ] && exit 0

echo "pr-cost: syncing cost ledger for PR #$pr before push…" >&2
python3 scripts/pr_cost_ledger.py sync --pr "$pr" >&2 || true

if ! git diff --quiet -- metrics/pr_cost/ 2>/dev/null \
   || ! git diff --cached --quiet -- metrics/pr_cost/ 2>/dev/null; then
  echo "" >&2
  echo "pr-cost: ledger/report updated for PR #$pr." >&2
  echo "  Commit it, then push again:" >&2
  echo "    git add metrics/pr_cost/ && git commit -m 'chore(cost): sync PR #$pr ledger' && git push" >&2
  exit 1
fi
exit 0
